// Prisma schema — zeromultas
// MVP: gerador de recursos de multa (defesa prévia + JARI)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum OrderStatus {
  analisado
  aguardando_pagamento
  pago
  gerado
  entregue
  vencido
}

enum Fase {
  defesa_previa
  jari
  cetran
  vencido
}

enum PrazoStatus {
  valido
  vencido
}

enum TipoNotificacao {
  NA
  NP
  desconhecido
}

enum PromptTipo {
  analise
  geracao_defesa_previa
  geracao_jari
  geracao_cetran
  extracao_cnh
  extracao_completa
}

model Order {
  id                    String        @id @default(cuid())
  status                OrderStatus   @default(analisado)
  valor_multa_centavos  Int?
  faixa_id              Int?
  preco_centavos        Int?
  tribopay_hash         String?       @unique
  fase                  Fase?
  prazo_limite          DateTime?
  prazo_status          PrazoStatus?
  download_token        String?       @unique
  utm_source            String?
  utm_medium            String?
  utm_campaign          String?
  utm_content           String?
  utm_term              String?
  gclid                 String?
  fbclid                String?
  fbp                   String?
  fbc                   String?
  created_at            DateTime      @default(now())
  updated_at            DateTime      @updatedAt
  data_missing          Boolean       @default(false)
  valor_missing         Boolean       @default(false)
  cnh_manual            Boolean       @default(false)
  analise_status            AnaliseStatus?
  tipo_documento            String?
  verificado                Boolean       @default(true)
  origem_dados              OrigemDados   @default(analise)
  modo_geracao              ModoGeracao?
  vicios_finais             Json?
  score_band                ScoreBand?
  permite_arguir_sumula_312 Boolean       @default(false)
  analisado_em          DateTime?
  dados_em              DateTime?
  checkout_em           DateTime?
  paid_at               DateTime?
  generated_at          DateTime?

  fine_data           FineData?
  manual_fine_data    ManualFineData?
  driver_data  DriverData?
  driver_input DriverInput?
  recurso      Recurso?
  events       Event[]
  api_usage    ApiUsage[]
  price_tier   PriceTier?   @relation(fields: [faixa_id], references: [id])

  @@index([status])
  @@index([created_at])
}

model FineData {
  id                   Int              @id @default(autoincrement())
  order_id             String           @unique
  is_multa             Boolean?
  tipo_notificacao     TipoNotificacao?
  data_notificacao     DateTime?
  data_infracao        DateTime?
  num_ait              String?
  orgao_autuador       String?
  codigo_infracao      String?
  descricao_infracao   String?
  placa                String?
  veiculo              String?
  valor_multa_centavos Int?
  vicio_forte          Boolean?
  vicio_razao          String?
  vicios_detectados    Json?
  score                Int?
  raw_analise          Json?
  raw_extracao         Json?
  created_at           DateTime         @default(now())
  updated_at           DateTime         @updatedAt

  order Order @relation(fields: [order_id], references: [id], onDelete: Cascade)
}

model DriverData {
  id         Int      @id @default(autoincrement())
  order_id   String   @unique
  nome       String
  cpf        String
  num_cnh    String
  endereco   String
  cep        String?
  whatsapp   String?
  email      String?
  created_at DateTime @default(now())

  order Order @relation(fields: [order_id], references: [id], onDelete: Cascade)
}

model DriverInput {
  id                 Int      @id @default(autoincrement())
  order_id           String   @unique
  motivo_injustica   String   @db.Text
  consentimento_lgpd Boolean  @default(false)
  consentido_em      DateTime?
  created_at         DateTime @default(now())

  order Order @relation(fields: [order_id], references: [id], onDelete: Cascade)
}

model PriceTier {
  id                       Int      @id @default(autoincrement())
  faixa                    String
  valor_multa_min_centavos Int
  valor_multa_max_centavos Int
  preco_centavos           Int
  ativo                    Boolean  @default(true)
  created_at               DateTime @default(now())
  updated_at               DateTime @updatedAt

  orders Order[]

  @@index([ativo])
}

model PromptVersion {
  id          Int        @id @default(autoincrement())
  tipo        PromptTipo
  conteudo_md String     @db.Text
  versao      Int
  ativo       Boolean    @default(false)
  notas       String?
  created_at  DateTime   @default(now())
  updated_at  DateTime   @updatedAt

  @@unique([tipo, versao])
  @@index([tipo, ativo])
}

model Recurso {
  id        Int      @id @default(autoincrement())
  order_id  String   @unique
  texto     String   @db.Text
  pdf_path  String
  gerado_em DateTime @default(now())

  order Order @relation(fields: [order_id], references: [id], onDelete: Cascade)
}

model AdminUser {
  id            Int       @id @default(autoincrement())
  login         String    @unique
  senha_hash    String
  nome          String?
  created_at    DateTime  @default(now())
  last_login_at DateTime?
}

model Event {
  id         Int      @id @default(autoincrement())
  order_id   String?
  tipo       String
  metadata   Json?
  user_agent String?
  ip_hash    String?
  created_at DateTime @default(now())

  order Order? @relation(fields: [order_id], references: [id], onDelete: SetNull)

  @@index([tipo, created_at])
  @@index([order_id])
}

model Setting {
  key          String   @id
  type         String   // 'number' | 'text' | 'boolean'
  value_number Int?
  value_text   String?  @db.Text
  value_bool   Boolean?
  description  String
  group        String   @default("geral")
  updated_at   DateTime @updatedAt
}

model ApiUsage {
  id                          Int      @id @default(autoincrement())
  order_id                    String?
  kind                        String
  model                       String
  input_tokens                Int
  output_tokens               Int
  cache_creation_input_tokens Int      @default(0)
  cache_read_input_tokens     Int      @default(0)
  request_id                  String?
  created_at                  DateTime @default(now())

  order Order? @relation(fields: [order_id], references: [id], onDelete: SetNull)

  @@index([kind, created_at])
  @@index([order_id])
}

enum ModoGeracao {
  vicio_forte
  moderado
  generico
}

enum ScoreBand {
  alta
  media
  moderada_baixa
}

model AnalysisCache {
  hash       String   @id
  resultado  Json
  cnt_hits   Int      @default(0)
  created_at DateTime @default(now())
  expira_em  DateTime

  @@index([expira_em])
}

model UsageCounter {
  id         Int      @id @default(autoincrement())
  janela     String   @unique
  total      Int      @default(0)
  updated_at DateTime @updatedAt
}

model SecurityEvent {
  id          Int      @id @default(autoincrement())
  acao        String
  ip_hash     String?
  session_id  String?
  fingerprint String?
  regra       String?
  metadata    Json?
  created_at  DateTime @default(now())

  @@index([acao, created_at])
  @@index([ip_hash])
}

model FunnelEvent {
  id           BigInt   @id @default(autoincrement())
  session_id   String?
  order_id     String?
  step         String
  event_id     String?
  resultado    String?
  device       String?
  utm_source   String?
  utm_medium   String?
  utm_campaign String?
  gclid        String?
  fbclid       String?
  metadata     Json?
  created_at   DateTime @default(now())

  @@index([session_id])
  @@index([step, created_at])
  @@index([order_id])
}

model ConversionOutbox {
  id          BigInt    @id @default(autoincrement())
  order_id    String
  platform    String
  evento      String
  payload     Json
  status      String    @default("pendente")
  tentativas  Int       @default(0)
  last_error  String?
  created_at  DateTime  @default(now())
  sent_at     DateTime?

  @@unique([order_id, platform, evento])
  @@index([status, created_at])
  @@index([order_id])
}

model IntegrationConfig {
  key        String   @id
  value      String
  is_secret  Boolean  @default(false)
  updated_at DateTime @updatedAt
}

model EventMapping {
  id          Int      @id @default(autoincrement())
  step        String
  platform    String
  event_name  String
  enabled     Boolean  @default(true)
  value_cents Int?
  currency    String   @default("BRL")
  updated_at  DateTime @updatedAt

  @@unique([step, platform])
}


enum AnaliseStatus {
  valido
  multa_nao_suportada
  nao_multa
  ilegivel
  suspeito
  baixa_confianca
  schema_invalido
}

enum OrigemDados {
  analise
  manual
}

model ManualFineData {
  id                Int       @id @default(autoincrement())
  order_id          String    @unique
  tipo_notificacao  String?
  orgao_autuador    String?
  num_ait           String?
  codigo_infracao   String?
  descricao_infracao String?
  data_infracao     DateTime?
  data_notificacao  DateTime?
  placa             String?
  valor_centavos    Int?
  created_at        DateTime  @default(now())

  order Order @relation(fields: [order_id], references: [id], onDelete: Cascade)
}

model EmailOutbox {
  id                  Int       @id @default(autoincrement())
  order_id            String
  tipo                String
  destinatario        String
  status              String    @default("pendente")
  tentativas          Int       @default(0)
  last_error          String?
  provider_message_id String?
  created_at          DateTime  @default(now())
  sent_at             DateTime?

  @@unique([order_id, tipo])
  @@index([status, created_at])
  @@index([order_id])
}
